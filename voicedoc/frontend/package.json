{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:start": "electron .",
    "electron:dist": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.sasi.app",
    "productName": "SASI.AI",
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "../dist/VoiceDoc",
        "to": "VoiceDoc",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "dir"
    }
  },
  "dependencies": {
    "axios": "^1.16.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.15.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "vite": "^8.0.10",
    "wait-on": "^9.0.10"
  }
}
